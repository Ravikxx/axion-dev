{
  "manifest_version": 3,
  "name": "Axion",
  "version": "1.0.0",
  "description": "Axion AI browser assistant — ask questions and control any webpage",
  "permissions": ["sidePanel", "scripting", "storage", "tabs", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Open Axion",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_side_panel": {
      "suggested_key": { "default": "Alt+Shift+A" },
      "description": "Open Axion sidebar"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
